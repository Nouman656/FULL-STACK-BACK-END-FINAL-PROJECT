generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String      @id @default(uuid())
  name       String      @unique
  salary     Decimal     @default(0) @db.Decimal(12, 2)
  baseSalary Decimal     @default(0) @db.Decimal(12, 2)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  budgets    Budget[]
  monthPlans MonthPlan[]
}

model MonthPlan {
  id             String   @id @default(uuid())
  userId         String
  year           Int
  month          Int
  salarySnapshot Decimal  @db.Decimal(12, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  budgets Budget[]

  @@unique([userId, year, month])
  @@index([userId, year, month])
}

model Budget {
  id          String     @id @default(uuid())
  name        String
  amount      Decimal    @db.Decimal(12, 2)
  color       String
  userId      String
  monthPlanId String?
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  monthPlan   MonthPlan? @relation(fields: [monthPlanId], references: [id], onDelete: Cascade)
  expenses    Expense[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
  @@index([monthPlanId])
}

model Expense {
  id        String   @id @default(uuid())
  name      String
  amount    Decimal  @db.Decimal(12, 2)
  budgetId  String
  budget    Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([budgetId])
}
